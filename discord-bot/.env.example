# ============================================================================
# SMP Discord Bot — environment
# Copy to .env and fill in. The bot will refuse to start if a required
# field is missing so you can trust it when it boots clean.
# ============================================================================

# -- Discord ----------------------------------------------------------------
# Create the app at https://discord.com/developers/applications
# Enable: MESSAGE CONTENT INTENT, SERVER MEMBERS INTENT, PRESENCE INTENT
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# -- Channels ---------------------------------------------------------------
# Paste Discord channel IDs. Leave blank to disable a feature.
CHANNEL_CHAT=
CHANNEL_EVENTS=
CHANNEL_STATUS=
CHANNEL_ALERTS=
CHANNEL_AUDIT=
CHANNEL_RECAP=
CHANNEL_SOCIALS=
CHANNEL_TICKETS=
CHANNEL_SUGGESTIONS=
CHANNEL_WELCOME=

# Dynamic voice channels — display live counters in their name.
VOICE_PLAYER_COUNT=
VOICE_TPS=

# -- Roles ------------------------------------------------------------------
# Role IDs. Admin/mod roles gate moderation commands.
ROLE_ADMIN=
ROLE_MOD=
ROLE_LINKED=
ROLE_BOOSTER=

# -- Bridge (plugins -> bot) -----------------------------------------------
# WebSocket server exposed by the bot. Plugins connect here.
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8787
# Shared secret; must match plugins' discord-bridge.token.
BRIDGE_TOKEN=

# -- z.ai GLM (OpenAI-compatible) -------------------------------------------
# https://docs.z.ai/guides/develop/openai-compat (GLM Coding Plan)
AI_BASE_URL=https://api.z.ai/api/coding/paas/v4
AI_API_KEY=
AI_MODEL=glm-4.6
AI_MODERATION=true

# -- Mineflayer MC bot ------------------------------------------------------
MCBOT_ENABLED=true
MCBOT_HOST=127.0.0.1
MCBOT_PORT=25565
MCBOT_USERNAME=SaphirSMPAssistant
# Mot de passe utilisé par le bot pour /register puis /login sur le core-paper.
# 4-64 caractères, doit être différent du pseudo. Garde-le secret.
MCBOT_PASSWORD=change-me-long-random
# offline works because the proxy forwards, set a stable name.
MCBOT_AUTH=offline
MCBOT_VERSION=1.21.4

# -- Host monitoring --------------------------------------------------------
HOST_ALERT_CPU=90
HOST_ALERT_RAM=90
HOST_ALERT_DISK=95
HOST_ALERT_COOLDOWN_S=600

# -- Social feeds (optional) ------------------------------------------------
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_CHANNELS=
YOUTUBE_CHANNEL_IDS=
RSS_FEEDS=

# -- Meta -------------------------------------------------------------------
LOG_LEVEL=info
TIMEZONE=Europe/Paris
DATA_DIR=./data
